# ─────────────────────────────────────────────────────────────────────────────
# BJJFlow — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Safe to expose to the browser (anon key has RLS, not secrets)
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# DANGER: Bypasses all RLS. Server-side only. Never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Used for supabase gen types in package.json scripts
SUPABASE_PROJECT_ID=<your-project-id>

# ── Database (Drizzle direct connection) ─────────────────────────────────────
# Use the "Transaction" pooler URL for serverless (Vercel Edge / Lambdas).
# Use the "Session" pooler URL for migrations and drizzle-kit.
DATABASE_URL=postgresql://postgres.<project-id>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_<your-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-secret>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_<your-key>

# Stripe Price IDs — BRL plans
STRIPE_PRICE_STARTER_BRL=price_<id>
STRIPE_PRICE_GROWTH_BRL=price_<id>
STRIPE_PRICE_PRO_BRL=price_<id>

# Stripe Price IDs — EUR plans
STRIPE_PRICE_STARTER_EUR=price_<id>
STRIPE_PRICE_GROWTH_EUR=price_<id>
STRIPE_PRICE_PRO_EUR=price_<id>

# ── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=re_<your-key>
EMAIL_FROM=BJJFlow <noreply@mail.bjjflow.com>

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cron security ────────────────────────────────────────────────────────────
# Set a strong random secret. Used in Authorization header for cron routes.
CRON_SECRET=<generate-with-openssl-rand-hex-32>
